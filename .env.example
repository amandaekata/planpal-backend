# Server
PORT=8080
ENV=development

# Database (used by app and migrate)
DATABASE_URL=postgres://planpal:planpal@localhost:5432/planpal?sslmode=disable

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=http://localhost:*,https://your-flutter-app.com

# Optional: OAuth (e.g. Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Push notifications
# FCM_SERVER_KEY=
